---
---

<header class="sticky top-0 z-40 w-full h-16 bg-white/70 dark:bg-black/70 backdrop-blur-xl border-b border-hairline dark:border-zinc-900/80 transition-colors duration-200">
  <div class="max-w-7xl mx-auto h-full px-4 sm:px-6 lg:px-8 flex items-center justify-between">
    <!-- Logo & Suffix -->
    <div class="flex items-center space-x-3">
      <a href="/" class="flex items-center space-x-2.5 select-none group" aria-label="AirList home">
        <!-- Nothing Tech inspired dot-grid logo mark -->
        <div class="relative w-6 h-6 flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="2" y="2" width="4" height="4" rx="1" class="fill-ink dark:fill-white" />
            <rect x="10" y="2" width="4" height="4" rx="1" class="fill-ink dark:fill-white" />
            <rect x="18" y="2" width="4" height="4" rx="1" class="fill-nothing-red" />
            <rect x="2" y="10" width="4" height="4" rx="1" class="fill-ink dark:fill-white" />
            <rect x="10" y="10" width="4" height="4" rx="1" class="fill-nothing-red" />
            <rect x="18" y="10" width="4" height="4" rx="1" class="fill-ink dark:fill-white" />
            <rect x="2" y="18" width="4" height="4" rx="1" class="fill-nothing-red" />
            <rect x="10" y="18" width="4" height="4" rx="1" class="fill-ink dark:fill-white" />
            <rect x="18" y="18" width="4" height="4" rx="1" class="fill-ink dark:fill-white" />
          </svg>
        </div>
        <span class="text-sm font-mono font-bold tracking-tight text-ink dark:text-zinc-100 group-hover:text-nothing-red dark:group-hover:text-nothing-red transition-colors duration-150">AirList</span>
      </a>
    </div>

    <!-- Search / Command Palette Trigger (Desktop) -->
    <div class="hidden md:flex items-center flex-1 max-w-sm mx-8">
      <button 
        id="nav-search-btn"
        aria-label="Open command palette"
        class="w-full flex items-center justify-between px-3 py-2 bg-canvas-soft/60 dark:bg-zinc-950/60 backdrop-blur-sm border border-hairline dark:border-zinc-800 hover:border-hairline-strong dark:hover:border-zinc-700 text-mute dark:text-zinc-500 rounded-lg text-xs text-left cursor-pointer transition-all duration-200 hover:bg-white dark:hover:bg-zinc-900/80"
      >
        <div class="flex items-center space-x-2">
          <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <span class="font-sans">Search or type a command…</span>
        </div>
        <kbd class="hidden sm:inline-flex items-center font-mono text-[10px] tracking-wide bg-white dark:bg-zinc-900 border border-hairline dark:border-zinc-800 px-1.5 py-0.5 rounded-md select-none text-mute dark:text-zinc-500">
          ⌃&nbsp;K
        </kbd>
      </button>
    </div>

    <!-- Right Side Actions -->
    <div class="flex items-center space-x-3">
      <!-- Active Tasks Badge with Nothing Red dot -->
      <div id="header-active-count-container" class="hidden sm:flex items-center space-x-1.5 text-xs text-body dark:text-zinc-400">
        <span class="w-1.5 h-1.5 rounded-full bg-nothing-red animate-indicator-pulse flex-shrink-0" aria-hidden="true"></span>
        <span class="font-mono" id="header-active-count">0 pending</span>
      </div>

      <!-- Divider -->
      <span class="hidden sm:inline-block w-px h-4 bg-hairline dark:bg-zinc-800" aria-hidden="true"></span>

      <!-- Theme Toggle -->
      <button 
        id="theme-toggle"
        aria-label="Toggle visual theme"
        class="p-2 text-body hover:text-ink dark:text-zinc-400 dark:hover:text-white rounded-xl bg-transparent hover:bg-canvas-soft dark:hover:bg-zinc-900 border border-transparent hover:border-hairline dark:hover:border-zinc-800 cursor-pointer transition-all duration-200"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg id="theme-toggle-light-icon" class="hidden w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"></path>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="theme-toggle-dark-icon" class="hidden w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
        </svg>
      </button>

      <!-- GitHub Link -->
      <a 
        href="https://github.com/Noorthistime/AirList" 
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View source on GitHub"
        class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 bg-primary text-on-primary dark:bg-zinc-100 dark:text-primary hover:bg-nothing-red dark:hover:bg-nothing-red dark:hover:text-white text-xs font-mono font-bold rounded-xl tracking-tight select-none transition-all duration-200"
      >
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </div>
  </div>
</header>

<script>
  // Setup theme toggle interaction
  const themeToggleBtn = document.getElementById('theme-toggle');
  const lightIcon = document.getElementById('theme-toggle-light-icon');
  const darkIcon = document.getElementById('theme-toggle-dark-icon');

  function updateIcons() {
    if (document.documentElement.classList.contains('dark')) {
      lightIcon?.classList.remove('hidden');
      darkIcon?.classList.add('hidden');
    } else {
      lightIcon?.classList.add('hidden');
      darkIcon?.classList.remove('hidden');
    }
  }

  // Initial update
  updateIcons();

  themeToggleBtn?.addEventListener('click', () => {
    if (document.documentElement.classList.contains('dark')) {
      document.documentElement.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      document.documentElement.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
    updateIcons();
    // Dispatch custom event so other components (charts, timers) can react to theme changes
    window.dispatchEvent(new Event('themechange'));
  });

  // Search button click redirects focus to Command Palette
  const navSearchBtn = document.getElementById('nav-search-btn');
  navSearchBtn?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('toggle-command-palette'));
  });
</script>
